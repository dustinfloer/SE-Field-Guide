{
  "schema_version": "0.1",
  "merchant": {
    "name": "Acme Supplies",
    "slug": "acme-supplies",
    "industry": "Industrial supplies",
    "business_model": "B2B",
    "website": "https://example.com"
  },
  "deck": {
    "title": "Shopify x Acme Supplies - B2B Demo",
    "audience": "merchant",
    "primary_goal": "Collaborative demo deck for a sales-led B2B evaluation",
    "source_html": "index.html",
    "merchant_pdf": "exports/acme-supplies-demo-deck.pdf",
    "internal_review_pdf": "exports/acme-supplies-demo-deck-internal.pdf"
  },
  "speakers": [
    {
      "name": "AE Name",
      "role": "AE"
    },
    {
      "name": "SE Name",
      "role": "SE"
    }
  ],
  "brand": {
    "mode": "merchant-accent",
    "preset_id": "shopify-teal",
    "preset_label": "Shopify Teal",
    "accent": "#14a098",
    "accent_bright": "#1cc7bd",
    "font_preset_id": "inter",
    "font_preset_label": "Inter",
    "heading_font": "Inter",
    "body_font": "Inter",
    "motion_preset_id": "standard",
    "motion_preset_label": "Standard",
    "logo_path": "acme_logo.png",
    "logo_alt": "Acme Supplies logo",
    "logo_embedded": false,
    "logo_source_url": null
  },
  "workflow": {
    "creative_mode": "collaborative",
    "export_target": "pdf",
    "default_share_path": "merchant-safe-pdf",
