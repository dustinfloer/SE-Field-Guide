  "studio": {
    "slide_picker": {
      "version": 1,
      "updated_at": null,
      "modules": {}
    }
  },
  "strategy": {
    "deck_type": "b2b",
    "has_b2b": true,
    "has_dtc": false,
    "plus_sales_deck": true,
    "ai_moment_required": false,
    "sidekick_required": true,
    "pricing_required": true
  },
  "source_policy": {
    "notes": "Evidence is internal scaffolding for confidence. It is not exported to the merchant PDF unless explicitly requested.",
    "required_for": [
      "discovery-recap",
      "merchant-quote",
      "pricing",
      "stack-or-integration-claim",
      "case-study-metric"
    ],
    "optional_for": [
      "shopify-platform-overview",
      "agenda",
      "section-header",
      "closing"
    ]
  },
  "sources": [
    {
      "id": "briefing",
      "type": "local",
      "path": "briefing-document.md",
      "label": "Briefing document"
    },
    {
      "id": "salesforce",
      "type": "salesforce",
      "label": "Salesforce opportunity"
    }
  ],
  "slides": [
    {
      "id": "cover",
      "pattern": "cover",
      "speaker": "AE Name",
      "evidence": []
    },
    {
      "id": "discovery-recap",
      "pattern": "discovery-recap",
      "speaker": "AE Name",
      "evidence": [
        "briefing"
      ]
    },
    {
      "id": "buyer-journey",
      "pattern": "feature-slide",
      "speaker": "SE Name",
      "evidence": [
        "briefing"
      ]
    }
  ]
